{
    "title": "Annual Report / Filings Extractor Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "input_mode": {
            "title": "Input Mode",
            "type": "string",
            "description": "How to provide the annual report(s). Use 'pdf_urls' for direct PDF links, 'company_names' for auto-discovery via SEC EDGAR/web, or 'mixed' for both.",
            "enum": ["pdf_urls", "company_names", "mixed"],
            "default": "company_names",
            "editor": "select"
        },
        "pdf_urls": {
            "title": "PDF Report URLs",
            "type": "array",
            "description": "Direct URLs to annual report or filing PDFs.",
            "editor": "stringList",
            "items": {
                "type": "string"
            },
            "example": [
                "https://www.sec.gov/Archives/edgar/data/320193/000032019324000123/aapl-20240928.htm"
            ]
        },
        "company_name_list": {
            "title": "Company Name List",
            "type": "array",
            "description": "List of company names or ticker symbols.",
            "editor": "stringList",
            "items": {
                "type": "string"
            },
            "example": ["Apple", "Microsoft", "NVDA"]
        },
        "report_year": {
            "title": "Report Year Filter",
            "type": "integer",
            "description": "Target fiscal year for reports. Leave empty for the most recent.",
            "minimum": 2000,
            "maximum": 2030,
            "editor": "number"
        },
        "filing_types": {
            "title": "Filing Types",
            "type": "array",
            "description": "SEC filing types to consider.",
            "editor": "stringList",
            "items": {
                "type": "string",
                "enum": ["10-K", "20-F", "10-K/A", "20-F/A", "Annual Report"]
            },
            "default": ["10-K", "20-F"]
        },
        "extraction_focus": {
            "title": "Extraction Focus Areas",
            "type": "array",
            "description": "Which intelligence categories to extract.",
            "editor": "stringList",
            "items": {
                "type": "string",
                "enum": [
                    "capex_focus",
                    "digital_initiatives",
                    "investment_areas",
                    "strategic_priorities",
                    "risk_mentions",
                    "intent_signals",
                    "technology_spend",
                    "m_and_a_signals",
                    "workforce_signals",
                    "sustainability_capex"
                ]
            },
            "default": [
                "capex_focus",
                "digital_initiatives",
                "investment_areas",
                "strategic_priorities",
                "risk_mentions",
                "intent_signals"
            ]
        },
        "min_evidence_confidence": {
            "title": "Minimum Evidence Confidence Score",
            "type": "number",
            "description": "Filter threshold (0.0–1.0).",
            "minimum": 0,
            "maximum": 1,
            "default": 0.65,
            "editor": "number"
        },
        "max_pages_per_doc": {
            "title": "Max Pages to Process Per Document",
            "type": "integer",
            "description": "Limit pages processed per PDF. Set to 0 for unlimited.",
            "default": 200,
            "minimum": 0,
            "maximum": 500,
            "editor": "number"
        },
        "anthropic_api_key": {
            "title": "Anthropic API Key (Optional)",
            "type": "string",
            "description": "Your Anthropic API key.",
            "editor": "textfield",
            "isSecret": true
        },
        "openai_api_key": {
            "title": "OpenAI API Key (Optional)",
            "type": "string",
            "description": "Your OpenAI API key.",
            "editor": "textfield",
            "isSecret": true
        },
        "proxy_configuration": {
            "title": "Proxy Configuration",
            "type": "object",
            "description": "Apify proxy settings.",
            "editor": "proxy",
            "default": { "useApifyProxy": true }
        },
        "output_format": {
            "title": "Output Format",
            "type": "string",
            "description": "Structure of the output dataset.",
            "enum": ["full", "compact", "signals_only"],
            "default": "full",
            "editor": "select"
        },
        "notify_webhook_url": {
            "title": "Webhook Notification URL (Optional)",
            "type": "string",
            "description": "POST results to this URL.",
            "editor": "textfield"
        }
    },
    "required": ["input_mode"]
}
